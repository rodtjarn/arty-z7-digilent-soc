# Vivado generated project directories
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/
*.gen/

# Vivado logs and journals
vivado.jou
vivado.log
vivado_*.backup.jou
vivado_*.backup.log
vivado_*.jou
vivado_*.log
xvlog.pb
clockInfo.txt

# Vivado checkpoint / report files
*.dcp
*.rpt

# Xilinx scratch directory
.Xil/

# Compiled outputs
*.o
*.elf
*.bin

# Records the hash of the last bitstream flashed to hardware (sw/run_gpio_test.tcl)
sw/.program_stamp

# Old/scratch Vivado project (use arty-z7-counter/ instead)
counter/

# Scratch xsdb debug scripts (the working one is sw/run_gpio_test.tcl)
arty-z7-soc/scripts/xsdb_*.tcl
arty-z7-soc/scripts/vivado_*.tcl
arty-z7-soc/scripts/vivado_*.jou
arty-z7-soc/scripts/vivado_*.log
arty-z7-soc/scripts/vivado.jou
arty-z7-soc/scripts/vivado.log
arty-z7-counter/scripts/vivado_*.jou
arty-z7-counter/scripts/vivado_*.log
arty-z7-counter/scripts/vivado.jou
arty-z7-counter/scripts/vivado.log

# Vivado project files inside bin/ (stray arty-z7-counter build artifacts)
arty-z7-counter/bin/*.xpr
arty-z7-counter/bin/*.cache
arty-z7-counter/bin/*.hw
arty-z7-counter/bin/*.ip_user_files

# arty-z7-soc project file and stray report dir, both regenerated fresh by
# `create_project -force` in build.tcl on every run
arty-z7-soc/hw/*.xpr
arty-z7-soc/scripts/NA/

# Linux boot chain (linux/): cloned upstream sources and build output. Only
# the board dts files, bif/boot script, and Makefiles are source-controlled;
# everything else is regenerated by `make -C linux all`.
linux/fsbl/vitis_ws/
linux/u-boot/src/
linux/kernel/src/
linux/rootfs/src/
linux/rootfs/initramfs/
linux/rootfs/rootfs.cpio.gz
linux/rootfs/uramdisk.image.gz
linux/boot/BOOT.BIN
linux/boot/boot.scr
linux/.xlsclients-shim/
