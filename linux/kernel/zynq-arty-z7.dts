// SPDX-License-Identifier: GPL-2.0+
/*
 * Digilent Arty Z7-10 (xc7z010clg400-1)
 *
 * PS7 config matches Digilent's official Vivado board preset
 * (arty-z7-10/A.0/preset.xml): DDR3 MT41J256M16 (512MB, 16-bit bus),
 * UART0 on MIO 14..15, SD0 on MIO 40..45 with card detect on MIO 47.
 */
/dts-v1/;
#include "zynq-7000.dtsi"

/ {
	model = "Digilent Arty Z7 board";
	compatible = "digilentinc,zynq-arty-z7", "xlnx,zynq-7000";

	aliases {
		serial0 = &uart0;
		mmc0 = &sdhci0;
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x20000000>;
	};

	chosen {
		bootargs = "console=ttyPS0,115200 earlyprintk";
		stdout-path = "serial0:115200n8";
	};
};

&clkc {
	/* See u-boot/zynq-arty-z7.dts: Arty Z7's PS_CLK is a 50 MHz oscillator,
	 * not the 33.333 MHz assumed elsewhere -- wrong here miscomputes every
	 * PLL-derived clock (including the UART baud clock) from the live SLCR
	 * registers. */
	ps-clk-frequency = <50000000>;
};

&sdhci0 {
	status = "okay";
};

&uart0 {
	status = "okay";
};
